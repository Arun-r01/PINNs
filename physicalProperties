// NACA4412 at Re_c = 200,000
// Re_c = U_inf * c / nu  =>  nu = U_inf * c / Re_c = 1 * 1 / 200000 = 5e-6 m^2/s

viscosityModel  constant;

rho             [1 -3 0 0 0 0 0] 1;

nu              [0 2 -1 0 0 0 0] 5e-06;

