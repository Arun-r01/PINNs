FoamFile
{
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// NACA0012 at Re_c = 200,000, AoA = 5 degrees
// k    = 3.75e-5 m^2/s^2   (I = 0.5%)
// nu   = 5e-6   m^2/s      (Re_c = 200,000)
// Target nut/nu = 0.1  (clean freestream):
//   nut_target = 0.1 * nu = 0.1 * 5e-6 = 5e-7 m^2/s
//   omega = k / nut_target = 3.75e-5 / 5e-7 = 75 s^-1
//
// Cross-check via turbulent length scale L:
//   L ~ 0.35% chord = 0.0035 m
//   omega = sqrt(k) / (Cmu^0.25 * L) = 0.006124 / (0.5477 * 0.0035) ~ 75 s^-1  [consistent]
//
// Patch names match blockMeshDict: inlet, outlet, aerofoil, back, front

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 75;

boundaryField
{
    // ── Full farfield C-mesh boundary ─────────────────────────────────────────
    inlet
    {
        type            freestream;
        freestreamValue uniform 75;
    }

    // ── Wake / trailing-edge exit boundary ───────────────────────────────────
    outlet
    {
        type            zeroGradient;
    }

    // ── Airfoil surface ───────────────────────────────────────────────────────
    // omegaWallFunction: applies automatic switching between viscous sublayer
    // and log-law formulation — correct for k-omega SST at y+~1
    aerofoil
    {
        type            omegaWallFunction;
        value           uniform 75;
    }

    // ── Spanwise empty patches (2-D simulation) ───────────────────────────────
    back
    {
        type            empty;
    }

    front
    {
        type            empty;
    }
}

